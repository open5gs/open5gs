#        session:
#          - name: internet
#            type: 3
#            lbo_roaming_allowed: false
#            ue:
#              ipv4: 10.45.0.5
#              ipv6: 2001:db8:cafe::5
#            ambr:
#              downlink:
#                value: 1
#                unit: 3
#              uplink:
#                value: 1
#                unit: 3
#            qos:
#              index: 9
#              arp:
#                priority_level: 8
#                pre_emption_vulnerability: 1
#                pre_emption_capability: 1
#
#      - sst: 2
#        sd: "000002"
